generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum PipelineStage {
  FIRMA_IDENTIFIZIERT
  FIRMA_KONTAKTIERT
  MEETING_VEREINBART
  VERHANDLUNG
  CLOSED_WON
  CLOSED_LOST
}

enum EntityType {
  COMPANY
  CONTACT
}

enum MeetingStatus {
  MEETING_SET
  MEETING_DONE
}

enum NotificationType {
  TASK_ASSIGNED
  STAGE_CHANGED
  COMMENT_ADDED
  OVERDUE_REMINDER
  SYSTEM
  CHAT_MENTION
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          Role      @default(USER)
  refreshToken  String?   // deprecated — kept for backward compat, use RefreshToken table
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?

  totpSecret    String?
  totpEnabled   Boolean   @default(false)

  assignedCompanies Company[] @relation("AssignedTo")
  createdCompanies  Company[] @relation("CreatedBy")
  comments          Comment[]
  createdTasks      Task[]    @relation("TaskCreatedBy")
  assignedTasks     Task[]    @relation("TaskAssignedTo")
  activities        Activity[]
  notifications     Notification[]
  attachments       Attachment[]
  savedViews        SavedView[]
  createdContracts  Contract[] @relation("ContractCreatedBy")
  chatMessages      ChatMessage[]
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Company {
  id            String        @id @default(uuid())
  name          String
  website       String?
  city          String?
  pipelineStage PipelineStage?

  perplexityResult   String?
  perplexityFetchedAt DateTime?

  eigenkapital   String?
  verlustvortrag String?
  gewinnvortrag  String?

  expectedRevenue  Float?
  uisSchwierigkeiten Boolean @default(false)
  uisReason        String?
  doNotCall        Boolean @default(false)
  isFavorite       Boolean @default(false)
  adminPipeline    Boolean @default(false)

  meetingStatus     MeetingStatus?
  meetingDate       DateTime?
  meetingFollowUpAt DateTime?

  closeReason   String?
  closeNote     String?

  assignedToId  String?
  assignedTo    User?         @relation("AssignedTo", fields: [assignedToId], references: [id])

  createdById   String
  createdBy     User          @relation("CreatedBy", fields: [createdById], references: [id])

  contacts      Contact[]
  tasks         Task[]
  attachments   Attachment[]
  contracts     Contract[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([assignedToId])
  @@index([createdById])
  @@index([pipelineStage])
  @@map("companies")
}

model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  mobile    String?
  position  String?

  perplexityResult    String?
  perplexityFetchedAt DateTime?

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks     Task[]

  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("contacts")
}

model Comment {
  id         String     @id @default(uuid())
  content    String
  entityType EntityType
  entityId   String

  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime   @default(now())

  @@index([entityType, entityId])
  @@map("comments")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  done        Boolean   @default(false)
  doneAt      DateTime?

  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdById  String
  createdBy    User     @relation("TaskCreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?    @relation("TaskAssignedTo", fields: [assignedToId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([done, dueDate])
  @@index([assignedToId])
  @@index([createdById])
  @@map("tasks")
}

model Activity {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
  @@map("activities")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String
  fileSize  Int
  mimeType  String
  path      String

  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("attachments")
}

model Contract {
  id               String   @id @default(uuid())
  contractNumber   String   @unique
  durationMonths   Int
  commissionRate   Float    // % auf die Bescheinigten Projektkosten
  foerderquote     Float    @default(25)  // Förderquote in % (25-35)
  paymentBewilligung Int   @default(50)  // % bei Bewilligung
  paymentFinanzamt   Int   @default(50)  // % bei Einreichung beim Finanzamt
  zahlungsfrist      Int   @default(14)  // Zahlungsfrist in Tagen
  verguetungsVariante    String  @default("A")   // "A" or "B"
  verguetungsSatzB       Float   @default(12)    // % for Variante B
  tagessatz              Float   @default(1500)  // EUR Tagessatz
  stundensatz            Float   @default(200)   // EUR Stundensatz
  haftungProSchadensfall Float   @default(50000) // EUR pro Schadensfall
  haftungProKalenderjahr Float   @default(250000) // EUR pro Kalenderjahr
  street           String
  streetNumber     String
  zipCode          String
  city             String
  country          String   @default("Deutschland")

  pdfPath          String?
  pdfGeneratedAt   DateTime?

  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById      String
  createdBy        User     @relation("ContractCreatedBy", fields: [createdById], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([contractNumber])
  @@map("contracts")
}

model SavedView {
  id       String  @id @default(uuid())
  name     String
  filters  Json
  isGlobal Boolean @default(false)

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("saved_views")
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String?

  fileName  String?
  fileSize  Int?
  mimeType  String?
  filePath  String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("chat_messages")
}
